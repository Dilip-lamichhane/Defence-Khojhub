# Frontend Environment Variables
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
VITE_API_URL=http://localhost:5000/api/v1
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Supabase (Active project switch)
VITE_ACTIVE_SUPABASE_PROJECT=REAL  # DUMMY or REAL

# Dummy Database (Geospatial/Location Only)
VITE_DUMMY_SUPABASE_URL=https://your-dummy-project.supabase.co
VITE_DUMMY_SUPABASE_ANON_KEY=your_dummy_anon_key
VITE_DUMMY_SUPABASE_PUBLISHABLE_KEY=your_dummy_publishable_key

# Real Database (Full Operations)
VITE_REAL_SUPABASE_URL=https://your-real-project.supabase.co
VITE_REAL_SUPABASE_ANON_KEY=your_real_anon_key
VITE_REAL_SUPABASE_PUBLISHABLE_KEY=your_real_publishable_key

# Supabase (fallback / legacy)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT=

# Storage
VITE_SUPABASE_PRODUCT_BUCKET=product-images
