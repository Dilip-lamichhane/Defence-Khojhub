# Server Configuration
PORT=5000
NODE_ENV=development
 CORS_ORIGIN=http://localhost:5173

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/khojhub

# Supabase (Active project switch)
ACTIVE_SUPABASE_PROJECT=REAL  # DUMMY or REAL

# Dummy Database (Geospatial/Location Only)
DUMMY_SUPABASE_URL=https://your-dummy-project.supabase.co
DUMMY_SUPABASE_ANON_KEY=your_dummy_anon_key
DUMMY_SUPABASE_PUBLISHABLE_KEY=your_dummy_publishable_key
DUMMY_SUPABASE_SERVICE_KEY=your_dummy_service_role_key
DUMMY_SUPABASE_SERVICE_ROLE_KEY=your_dummy_service_role_key
DUMMY_SUPABASE_JWT_SECRET=your_dummy_jwt_secret
DUMMY_SUPABASE_PROJECT=your_dummy_project_ref

# Real Database (Full Operations)
REAL_SUPABASE_URL=https://your-real-project.supabase.co
REAL_SUPABASE_ANON_KEY=your_real_anon_key
REAL_SUPABASE_PUBLISHABLE_KEY=your_real_publishable_key
REAL_SUPABASE_SERVICE_KEY=your_real_service_role_key
REAL_SUPABASE_SERVICE_ROLE_KEY=your_real_service_role_key
REAL_SUPABASE_JWT_SECRET=your_real_jwt_secret
REAL_SUPABASE_PROJECT=your_real_project_ref

# Supabase (Global / fallback)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_PROJECT=

# Authentication (legacy / optional)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=1d

# Clerk Authentication
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret

# Google Maps API (backend, if used)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
